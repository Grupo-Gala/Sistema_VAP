/**
 * Valida manager por email y devuelve:
 * - responsable
 * - conceptos permitidos
 * - secretarias activas
 */
function vap_bootstrapForEmail(email) {
  email = (email || "").trim().toLowerCase();
  if (!email) return { ok:false, error:"Email vacío." };

  const bbdd = SpreadsheetApp.openById(BBDD_SPREADSHEET_ID);

  const responsables = readTable_(bbdd.getSheetByName(BBDD_RESPONSABLES));
  const resp = responsables.find(r =>
    truthy_(r[COL_RESP_ACTIVA]) &&
    String(r[COL_RESP_EMAIL] || "").trim().toLowerCase() === email
  );

  if (!resp) return { ok:false, error:"Email no autorizado o manager inactivo en BBDD." };

  const respId = String(resp[COL_RESP_ID] || "").trim();
  const respNombre = String(resp[COL_RESP_NAME] || "").trim();
  const respEmail = String(resp[COL_RESP_EMAIL] || "").trim();

  const conceptosAll = readTable_(bbdd.getSheetByName(BBDD_CONCEPTOS))
    .filter(c => truthy_(c[COL_CONC_ACTIVO]))
    .map(c => ({
      id: String(c[COL_CONC_ID] || "").trim(),
      concepto: String(c[COL_CONC_NAME] || "").trim(),
      tipoValor: String(c[COL_CONC_TIPO] || "").trim()
    }))
    .filter(c => c.id && c.concepto);

  const respConc = readTable_(bbdd.getSheetByName(BBDD_RESP_CONC))
    .filter(rc =>
      truthy_(rc[COL_RESPCONC_ACTIVA]) &&
      String(rc[COL_RESPCONC_IDRESP] || "").trim() === respId
    )
    .map(rc => String(rc[COL_RESPCONC_IDCONC] || "").trim())
    .filter(Boolean);

  const conceptosPermitidos = conceptosAll
    .filter(c => respConc.includes(c.id))
    .sort((a,b) => a.concepto.localeCompare(b.concepto, "es"));

  if (conceptosPermitidos.length === 0) {
    return { ok:false, error:"Manager válido, pero sin conceptos activos asignados." };
  }

  const secretarias = readTable_(bbdd.getSheetByName(BBDD_SECRETARIAS))
    .filter(s => truthy_(s[COL_SEC_ALTA]))
    .map(s => ({
      id: String(s[COL_SEC_ID] || "").trim(),
      nombre: String(s[COL_SEC_NOMBRE] || "").trim()
    }))
    .filter(s => s.id && s.nombre)
    .sort((a,b) => a.nombre.localeCompare(b.nombre, "es"));

  return {
    ok: true,
    defaults: vap_getUiDefaults_(),
    responsable: { id: respId, nombre: respNombre, email: respEmail },
    conceptos: conceptosPermitidos,
    secretarias
  };
}

/**
 * NUEVO:
 * Devuelve envíos previos (Batch_ID) disponibles para corregir
 * para una combinación responsable + año + mes + concepto.
 *
 * @param {Object} q
 * @param {number} q.year
 * @param {number} q.month
 * @param {string} q.idResponsable
 * @param {string} q.idConcepto
 */
function vap_listCorrectionTargets(q) {
  try {
    const ss = SpreadsheetApp.getActive();
    const sh = ss.getSheetByName(SHEET_DATA);
    if (!sh) return { ok:false, error:`No existe la hoja "${SHEET_DATA}".` };

    const values = sh.getDataRange().getValues();
    if (values.length < 2) return { ok:true, items:[] };

    const header = values[0];
    const idx = indexMap_(header);

    const required = ["Timestamp","Batch_ID","Año","Mes","ID_Responsable","ID_Concepto","Concepto"];
    const missing = required.filter(c => idx[c] === undefined);
    if (missing.length) return { ok:false, error:"Faltan columnas en Data: " + missing.join(", ") };

    const year = Number(q && q.year);
    const month = Number(q && q.month);
    const idResp = String((q && q.idResponsable) || "").trim();
    const idConc = String((q && q.idConcepto) || "").trim();

    if (!year || !month || !idResp || !idConc) return { ok:true, items:[] };

    const map = new Map(); // batchId -> {ts, concepto}

    for (let r = 1; r < values.length; r++) {
      const row = values[r];

      if (Number(row[idx["Año"]]) !== year) continue;

      const mesRaw = String(row[idx["Mes"]] || "").trim();
      const mesNum = monthToNumSafe_(mesRaw);
      if (mesNum !== month) continue;

      if (String(row[idx["ID_Responsable"]] || "").trim() !== idResp) continue;
      if (String(row[idx["ID_Concepto"]] || "").trim() !== idConc) continue;

      const batchId = String(row[idx["Batch_ID"]] || "").trim();
      if (!batchId) continue;

      const ts = parseTimestamp_(row[idx["Timestamp"]]);
      if (!ts) continue;

      const concepto = String(row[idx["Concepto"]] || "").trim();

      const cur = map.get(batchId);
      if (!cur || ts.getTime() > cur.ts.getTime()) {
        map.set(batchId, { ts, concepto });
      }
    }

    const items = Array.from(map.entries())
      .map(([batchId, v]) => ({
        batchId,
        concepto: v.concepto,
        tsISO: v.ts.toISOString(),
        tsText: Utilities.formatDate(v.ts, TZ, "dd/MM/yyyy HH:mm")
      }))
      .sort((a,b) => b.tsISO.localeCompare(a.tsISO));

    return { ok:true, items };
  } catch (e) {
    return { ok:false, error:String(e && e.message ? e.message : e) };
  }
}

/** Convierte "Febrero" / "2" / "02" a número de mes */
function monthToNumSafe_(m) {
  const s = String(m || "").trim();
  const n = parseInt(s, 10);
  if (n >= 1 && n <= 12) return n;

  const norm = normalizeMonth_(s);
  if (!norm) return 0;

  const mm = parseInt(monthToNum_(norm), 10);
  return (mm >= 1 && mm <= 12) ? mm : 0;
}

/**
 * Guarda batch en Data + Logs + Errores
 * payload:
 * {year, month, responsable, concepto, modo, corrigeBatchId, tipoCorreccion, valores[]}
 */
function vap_submitBatch(payload) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const shData = ss.getSheetByName(SHEET_DATA);
  const shLogs = ss.getSheetByName(SHEET_LOGS);
  const shErr  = ss.getSheetByName(SHEET_ERRORS);

  const tsNow = new Date();
  const batchId = generateBatchId_();

  try {
    if (!shData) return { ok:false, error:`No existe hoja "${SHEET_DATA}".` };
    if (!shLogs) return { ok:false, error:`No existe hoja "${SHEET_LOGS}".` };
    if (!shErr)  return { ok:false, error:`No existe hoja "${SHEET_ERRORS}".` };

    const year = Number(payload.year);
    const month = Number(payload.month);
    if (!year || !month || month < 1 || month > 12) return { ok:false, error:"Año/mes inválidos." };

    const resp = payload.responsable || {};
    const conc = payload.concepto || {};
    const modo = String(payload.modo || "").trim().toUpperCase();

    if (!resp.id || !resp.email) return { ok:false, error:"Responsable inválido." };
    if (!conc.id || !conc.concepto) return { ok:false, error:"Concepto inválido." };
    if (modo !== "NUEVO" && modo !== "CORRECCION") return { ok:false, error:"Modo inválido." };

    const corrigeBatchId = String(payload.corrigeBatchId || "").trim();
    const tipoCorreccion = String(payload.tipoCorreccion || "").trim().toUpperCase();

    if (modo === "CORRECCION") {
      if (!corrigeBatchId) return { ok:false, error:"En corrección es obligatorio Corrige_Batch_ID." };
      if (tipoCorreccion !== "PARCIAL" && tipoCorreccion !== "TOTAL") {
        return { ok:false, error:"Tipo de corrección debe ser PARCIAL o TOTAL." };
      }
    }

    const isTotal = (modo === "CORRECCION" && tipoCorreccion === "TOTAL");

    const dataHeaders = getHeaders_(shData);
    const logHeaders  = getHeaders_(shLogs);
    const errHeaders  = getHeaders_(shErr);

    const mustData = ["Timestamp","Batch_ID","ID_Responsable","Año","Mes","ID_Concepto","Concepto","ID_Secretaria","Valor","Modo","Corrige_Batch_ID"];
    const missing = mustData.filter(h => !dataHeaders.includes(h));
    if (missing.length) return { ok:false, error:`Faltan columnas en Data: ${missing.join(", ")}` };

    const rows = [];
    const errRows = [];

    (payload.valores || []).forEach(v => {
      const idSec = String(v.idSecretaria || "").trim();
      const nomSec = String(v.nombreSecretaria || "").trim();
      const raw = String(v.valorStr ?? "").trim();

      if (!idSec) return;

      if (!raw) {
        if (!isTotal) return; // en PARCIAL, omitimos vacíos
      }

      const num = raw ? parseNumber_(raw) : 0;
      if (num === null) {
        errRows.push(buildRowByHeaders_(errHeaders, {
          Timestamp: tsNow,
          Batch_ID: batchId,
          ID_Responsable: resp.id,
          Mes: month,
          ID_Concepto: conc.id,
          ID_Secretaria: idSec,
          Valor_Intentado: raw,
          Error: "Valor no numérico"
        }));
        return;
      }

      rows.push(buildRowByHeaders_(dataHeaders, {
        Timestamp: tsNow,
        Batch_ID: batchId,
        ID_Responsable: resp.id,
        Nombre_Responsable: resp.nombre || "",
        Email_Responsable: resp.email || "",
        Año: year,
        Mes: month,
        ID_Concepto: conc.id,
        Concepto: conc.concepto,
        ID_Secretaria: idSec,
        "Nombre_Secretaria": nomSec,
        Tipo_Valor: conc.tipoValor || "",
        Valor: num,
        Source: "WEBAPP",
        Modo: modo,
        Corrige_Batch_ID: (modo === "CORRECCION" ? corrigeBatchId : "")
      }));
    });

    if (rows.length === 0 && errRows.length === 0) {
      return { ok:false, error:"No hay registros para enviar (todo vacío)." };
    }

    if (rows.length) {
      shData.getRange(shData.getLastRow()+1, 1, rows.length, dataHeaders.length).setValues(rows);
    }

    if (errRows.length) {
      shErr.getRange(shErr.getLastRow()+1, 1, errRows.length, errHeaders.length).setValues(errRows);
    }

    const accion = (modo === "NUEVO") ? "ENVIO" : "CORRECCION";
    const logRow = buildRowByHeaders_(logHeaders, {
      Timestamp: tsNow,
      Batch_ID: batchId,
      ID_Responsable: resp.id,
      "Acción": accion,
      "Nº_Registros": rows.length,
      Resultado: (rows.length ? "OK" : "ERROR"),
      Mensaje: (errRows.length ? `OK con ${errRows.length} error(es) en Errores.` : "OK"),
      Tipo_Correccion: (modo === "CORRECCION" ? tipoCorreccion : "")
    });
    shLogs.getRange(shLogs.getLastRow()+1, 1, 1, logHeaders.length).setValues([logRow]);

    // =====================================================
    // NUEVO: EMAIL AUTOMÁTICO A LA MANAGER (Batch_ID + resumen)
    // =====================================================
   try {
      sendNotificationEmail_(payload, { batchId, written: rows.length, errors: errRows.length }, tsNow);
    } catch (mailErr) {
      Logger.log("Email fallback error: " + mailErr);
    }

    return { ok:true, batchId, written: rows.length, errors: errRows.length };

  } catch (e) {
    try {
      const logHeaders = getHeaders_(shLogs);
      const row = buildRowByHeaders_(logHeaders, {
        Timestamp: new Date(),
        Batch_ID: batchId,
        ID_Responsable: payload?.responsable?.id || "",
        "Acción": "ERROR",
        "Nº_Registros": 0,
        Resultado: "ERROR",
        Mensaje: String(e && e.message ? e.message : e),
        Tipo_Correccion: payload?.tipoCorreccion || ""
      });
      shLogs.getRange(shLogs.getLastRow()+1, 1, 1, logHeaders.length).setValues([row]);
    } catch(_) {}

    return { ok:false, error:"Fallo interno al guardar. Revisa Logs." };
  }
}

/* =====================================================
 * HELPERS COMUNES
 * ===================================================== */

function indexMap_(headerRow) {
  const map = {};
  for (let c = 0; c < headerRow.length; c++) {
    const name = String(headerRow[c] || "").trim();
    if (name) map[name] = c;
  }
  return map;
}

function parseTimestamp_(v) {
  if (v instanceof Date) return v;
  const s = String(v || "").trim();
  if (!s) return null;
  const d = new Date(s);
  return isNaN(d.getTime()) ? null : d;
}

function normalizeMonth_(input) {
  const s = String(input || "").trim().toLowerCase();
  if (!s) return null;

  const n = parseInt(s, 10);
  if (n >= 1 && n <= 12) return numToMonth_(n);

  const map = {
    "enero":"Enero","febrero":"Febrero","marzo":"Marzo","abril":"Abril",
    "mayo":"Mayo","junio":"Junio","julio":"Julio","agosto":"Agosto",
    "septiembre":"Septiembre","setiembre":"Septiembre","octubre":"Octubre",
    "noviembre":"Noviembre","diciembre":"Diciembre"
  };
  return map[s] || null;
}

function sameMonth_(rowMonth, monthNorm) {
  const m = normalizeMonth_(rowMonth);
  return m === monthNorm;
}

function numToMonth_(n) {
  return ["Enero","Febrero","Marzo","Abril","Mayo","Junio","Julio","Agosto","Septiembre","Octubre","Noviembre","Diciembre"][n-1];
}

function monthToNum_(monthNorm) {
  const months = ["Enero","Febrero","Marzo","Abril","Mayo","Junio","Julio","Agosto","Septiembre","Octubre","Noviembre","Diciembre"];
  const i = months.indexOf(monthNorm);
  const num = i >= 0 ? i+1 : 0;
  return String(num).padStart(2, "0");
}

function normalizeConcept_(c) {
  const s = String(c || "").toUpperCase();
  if (s.includes("APTO")) return "APTOS";
  if (s.includes("FINANC")) return "FINANCIACIONES";
  if (s.includes("RESE")) return "RESEÑAS";
  if ((s.includes("SÁB") || s.includes("SAB")) && s.includes("50")) return "SABADOS_50";
  if ((s.includes("SÁB") || s.includes("SAB")) && s.includes("60")) return "SABADOS_60";
  if (s.includes("PUNTO")) return "HORAS_PUNTOS";
  return s.replace(/\s+/g, "_").replace(/[^\wÁÉÍÓÚÜÑ_]/g, "");
}

function log_(ss, { action, n, result, message }) {
  const sh = ss.getSheetByName(SHEET_LOGS);
  if (!sh) return;
  sh.appendRow([
    new Date(),
    "",
    "",
    action,
    n || 0,
    result || "",
    message || "",
    ""
  ]);
}

function readTable_(sheet) {
  if (!sheet) throw new Error("Hoja no encontrada en BBDD.");
  const values = sheet.getDataRange().getValues();
  if (values.length < 2) return [];

  const headers = values[0].map(h => String(h || "").trim());
  const out = [];
  for (let i = 1; i < values.length; i++) {
    const row = values[i];
    if (row.every(c => c === "" || c === null)) continue;
    const obj = {};
    headers.forEach((h, idx) => obj[h] = row[idx]);
    out.push(obj);
  }
  return out;
}

function getHeaders_(sheet) {
  return sheet.getRange(1,1,1,sheet.getLastColumn()).getValues()[0].map(h => String(h||"").trim());
}

function buildRowByHeaders_(headers, obj) {
  return headers.map(h => (h in obj) ? obj[h] : "");
}

function truthy_(v) {
  if (v === true) return true;
  const s = String(v || "").toLowerCase().trim();
  return s === "true" || s === "1" || s === "yes" || s === "si" || s === "sí";
}

function generateBatchId_() {
  const now = new Date();
  const stamp = Utilities.formatDate(now, TZ, "yyyyMMdd_HHmmss");
  const rnd = Math.floor(Math.random() * 9000) + 1000;
  return `BATCH_${stamp}_${rnd}`;
}

function parseNumber_(s) {
  if (s === null || s === undefined) return null;
  s = String(s).trim();
  if (!s) return null;
  s = s.replace(/\s/g, "");

  const lastComma = s.lastIndexOf(",");
  const lastDot = s.lastIndexOf(".");
  if (lastComma > -1 && lastDot > -1) {
    if (lastComma > lastDot) {
      s = s.replace(/\./g, "").replace(",", ".");
    } else {
      s = s.replace(/,/g, "");
    }
  } else if (lastComma > -1) {
    s = s.replace(",", ".");
  }
  const n = Number(s);
  return isNaN(n) ? null : n;
}
function getNotificationEmailsByType_(tipo) {
  const bbdd = SpreadsheetApp.openById(BBDD_SPREADSHEET_ID);
  const sheet = bbdd.getSheetByName("Config");
  if (!sheet) return [];

  const data = sheet.getDataRange().getValues();
  const emails = [];

  for (let i = 1; i < data.length; i++) {
    const rowTipo   = String(data[i][0] || "").trim();
    const rowEmail  = String(data[i][1] || "").trim();
    const rowActivo = truthy_(data[i][2]);

    if (!rowActivo) continue;
    if (rowTipo !== tipo) continue;
    if (!rowEmail) continue;
    emails.push(rowEmail);
  }
  return emails;
}

