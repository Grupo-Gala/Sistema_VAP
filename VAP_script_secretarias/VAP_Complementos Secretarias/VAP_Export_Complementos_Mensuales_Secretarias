/**
 * Bootstrap para la WebApp de consulta.
 * Valida el email y devuelve los períodos disponibles (año+mes únicos).
 */
function vap_consultaBootstrap(email) {
  try {
    email = String(email || "").trim().toLowerCase();
    if (!email) return { ok: false, error: "Email vacío." };

    const bbdd = SpreadsheetApp.openById(BBDD_SPREADSHEET_ID);
    const responsables = readTable_(bbdd.getSheetByName(BBDD_RESPONSABLES));
    const resp = responsables.find(r =>
      truthy_(r[COL_RESP_ACTIVA]) &&
      String(r[COL_RESP_EMAIL] || "").trim().toLowerCase() === email
    );
    if (!resp) return { ok: false, error: "Email no autorizado o manager inactivo." };

    const respId = String(resp[COL_RESP_ID] || "").trim();

    const ss = SpreadsheetApp.getActive();
    const sh = ss.getSheetByName(SHEET_DATA);
    if (!sh) return { ok: false, error: `No existe la hoja "${SHEET_DATA}".` };

    const values = sh.getDataRange().getValues();
    if (values.length < 2) return {
      ok: true,
      responsable: { id: respId, nombre: String(resp[COL_RESP_NAME]||"").trim(), email: String(resp[COL_RESP_EMAIL]||"").trim() },
      periodos: []
    };

    const header = values[0];
    const idx = indexMap_(header);

    const periodosSet = new Map();
    for (let r = 1; r < values.length; r++) {
      const row = values[r];
      if (String(row[idx["ID_Responsable"]] || "").trim() !== respId) continue;

      const year  = Number(row[idx["Año"]]);
      const month = monthToNumSafe_(String(row[idx["Mes"]] || ""));
      if (!year || !month) continue;

      const key = `${year}_${month}`;
      if (!periodosSet.has(key)) periodosSet.set(key, { year, month });
    }

    const periodos = Array.from(periodosSet.values())
      .sort((a,b) => b.year - a.year || b.month - a.month);

    return {
      ok: true,
      responsable: {
        id    : respId,
        nombre: String(resp[COL_RESP_NAME]  || "").trim(),
        email : String(resp[COL_RESP_EMAIL] || "").trim()
      },
      periodos
    };

  } catch(e) {
    return { ok: false, error: String(e && e.message ? e.message : e) };
  }
}

/**
 * Devuelve los últimos 5 batches de un manager para un año+mes concreto.
 */
function vap_consultaBatches(q) {
  try {
    const respId = String((q && q.idResponsable) || "").trim();
    const year   = Number(q && q.year);
    const month  = Number(q && q.month);

    if (!respId || !year || !month) return { ok: false, error: "Parámetros inválidos." };

    const ss = SpreadsheetApp.getActive();
    const sh = ss.getSheetByName(SHEET_DATA);
    if (!sh) return { ok: false, error: `No existe la hoja "${SHEET_DATA}".` };

    const values = sh.getDataRange().getValues();
    if (values.length < 2) return { ok: true, batches: [] };

    const header = values[0];
    const idx = indexMap_(header);

    const batchMap = new Map();

    for (let r = 1; r < values.length; r++) {
      const row = values[r];
      if (String(row[idx["ID_Responsable"]] || "").trim() !== respId) continue;
      if (Number(row[idx["Año"]]) !== year) continue;
      if (monthToNumSafe_(String(row[idx["Mes"]] || "")) !== month) continue;

      const batchId = String(row[idx["Batch_ID"]] || "").trim();
      if (!batchId) continue;

      const ts = parseTimestamp_(row[idx["Timestamp"]]);
      if (!ts) continue;

      if (!batchMap.has(batchId)) {
        batchMap.set(batchId, {
          batchId,
          ts,
          concepto      : String(row[idx["Concepto"]] || "").trim(),
          modo          : String(row[idx["Modo"]] || "NUEVO").trim().toUpperCase(),
          corrigeBatchId: String(row[idx["Corrige_Batch_ID"]] || "").trim(),
          rows          : []
        });
      }

      const entry = batchMap.get(batchId);
      if (ts.getTime() > entry.ts.getTime()) entry.ts = ts;

      entry.rows.push({
        idSecretaria    : String(row[idx["ID_Secretaria"]] || "").trim(),
        nombreSecretaria: String(row[idx["Nombre_Secretaria"]] || "").trim(),
        valor           : row[idx["Valor"]]
      });
    }

    // Leer tipoCorreccion desde Logs
    const logsMap = new Map();
    const shLogs = ss.getSheetByName(SHEET_LOGS);
    if (shLogs) {
      const logVals = shLogs.getDataRange().getValues();
      const lh = indexMap_(logVals[0]);
      if (lh["Batch_ID"] !== undefined && lh["Tipo_Correccion"] !== undefined) {
        for (let r = 1; r < logVals.length; r++) {
          const bid = String(logVals[r][lh["Batch_ID"]] || "").trim();
          const tc  = String(logVals[r][lh["Tipo_Correccion"]] || "").trim();
          if (bid && tc) logsMap.set(bid, tc);
        }
      }
    }

    const batches = Array.from(batchMap.values())
      .sort((a,b) => b.ts.getTime() - a.ts.getTime())
      .slice(0, 5)
      .map(b => ({
        batchId        : b.batchId,
        tsText         : Utilities.formatDate(b.ts, TZ, "dd/MM/yyyy HH:mm"),
        concepto       : b.concepto,
        modo           : b.modo,
        tipoCorreccion : logsMap.get(b.batchId) || "",
        corrigeBatchId : b.corrigeBatchId,
        nRegistros     : b.rows.length,
        secretarias    : b.rows
      }));

    return { ok: true, batches };

  } catch(e) {
    return { ok: false, error: String(e && e.message ? e.message : e) };
  }
}
