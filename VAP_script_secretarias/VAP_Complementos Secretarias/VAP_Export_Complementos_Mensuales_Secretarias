/**
 * Acción del menú: genera el Excel mensual y lo guarda en Drive.
 *
 * CAMBIOS APLICADOS:
 * 1) Soporta la nueva BBDD: ID_Secretaria será tu ID_Secre y el Excel muestra ID + Nombre.
 * 2) Pivot final:
 *    ["ID_Secretaria","Secretaria", ...conceptos]
 * 3) La “clave” vigente se basa en ID_Secretaria (y cae a nombre si faltara el ID).
 * 4) FIX export XLSX robusto: UrlFetchApp + OAuth (sin Drive API).
 */
function vap_generarExcelMensual() {
  const ss = SpreadsheetApp.getActive();
  const ui = SpreadsheetApp.getUi();

  const shData = ss.getSheetByName(SHEET_DATA);
  if (!shData) {
    ui.alert(`No existe la hoja "${SHEET_DATA}". Revisa el nombre.`);
    return;
  }

  const yearResp = ui.prompt("Generar Excel mensual", "Introduce el AÑO (ej: 2026):", ui.ButtonSet.OK_CANCEL);
  if (yearResp.getSelectedButton() !== ui.Button.OK) return;
  const year = parseInt(yearResp.getResponseText().trim(), 10);
  if (!year || year < 2000 || year > 2100) {
    ui.alert("Año inválido. Ejemplo válido: 2026");
    return;
  }

  const monthResp = ui.prompt(
    "Generar Excel mensual",
    "Introduce el MES (Enero..Diciembre o número 1..12):",
    ui.ButtonSet.OK_CANCEL
  );
  if (monthResp.getSelectedButton() !== ui.Button.OK) return;
  const monthInput = monthResp.getResponseText().trim();
  const monthNorm = normalizeMonth_(monthInput);
  if (!monthNorm) {
    ui.alert("Mes inválido. Usa: Enero..Diciembre o 1..12.");
    return;
  }

  const values = shData.getDataRange().getValues();
  if (values.length < 2) {
    ui.alert("La hoja Data no tiene registros.");
    return;
  }

  const header = values[0];
  const idx = indexMap_(header);

  const required = ["Timestamp","Año","Mes","ID_Secretaria","Nombre_Secretaria","ID_Concepto","Concepto","Valor"];
  const missing = required.filter(c => idx[c] === undefined);
  if (missing.length) {
    ui.alert("Faltan columnas en Data: " + missing.join(", "));
    return;
  }

  // Último registro por (Año,Mes,ID_Secretaria/Nombre,Concepto) según Timestamp
  const latest = new Map(); // key -> {ts, secId, secName, concepto, valor}
  for (let r = 1; r < values.length; r++) {
    const row = values[r];
    const rowYear = row[idx["Año"]];
    const rowMonth = String(row[idx["Mes"]] || "").trim();
    if (String(rowYear).trim() !== String(year)) continue;
    if (!sameMonth_(rowMonth, monthNorm)) continue;

    const ts = parseTimestamp_(row[idx["Timestamp"]]);
    if (!ts) continue;

    const secId = String(row[idx["ID_Secretaria"]] || "").trim();
    const secName = String(row[idx["Nombre_Secretaria"]] || "").trim();
    const concepto = String(row[idx["Concepto"]] || "").trim();
    const valor = row[idx["Valor"]];

    if (!secId && !secName) continue;
    if (!concepto) continue;
    if (valor === "" || valor === null || valor === undefined) continue;

    const secKey = secId || secName;
    const key = `${year}||${monthNorm}||${secKey}||${concepto}`;

    const existing = latest.get(key);
    if (!existing || ts.getTime() > existing.ts.getTime()) {
      latest.set(key, { ts, secId, secName, concepto, valor });
    }
  }

  if (latest.size === 0) {
    ui.alert(`No hay datos para ${monthNorm} ${year}.`);
    return;
  }

  const secretariasMap = new Map(); // secKey -> {secId, secName}
  const conceptosSet = new Set();

  for (const rec of latest.values()) {
    const secKey = rec.secId || rec.secName;
    if (!secretariasMap.has(secKey)) {
      secretariasMap.set(secKey, { secId: rec.secId, secName: rec.secName });
    }
    conceptosSet.add(rec.concepto);
  }

  const conceptosAll = Array.from(conceptosSet);
  const preferred = [];
  const rest = [];

  for (const c of conceptosAll) {
    const norm = normalizeConcept_(c);
    if (CONCEPT_ORDER.includes(norm)) preferred.push(c);
    else rest.push(c);
  }

  preferred.sort((a,b) => CONCEPT_ORDER.indexOf(normalizeConcept_(a)) - CONCEPT_ORDER.indexOf(normalizeConcept_(b)));
  rest.sort((a,b) => a.localeCompare(b, "es"));
  const conceptosOrdered = preferred.concat(rest);

  const outHeader = ["ID_Secretaria", "Secretaria"].concat(conceptosOrdered);
  const out = [outHeader];

  const secList = Array.from(secretariasMap.entries())
    .map(([secKey, s]) => ({
      key: secKey,
      secId: s.secId || "",
      secName: s.secName || "",
      sortName: (s.secName || s.secId || secKey || "")
    }))
    .sort((a,b) => a.sortName.localeCompare(b.sortName, "es"));

  for (const s of secList) {
    const row = new Array(outHeader.length).fill("");
    row[0] = s.secId || "";
    row[1] = s.secName || "";

    for (let i = 0; i < conceptosOrdered.length; i++) {
      const concepto = conceptosOrdered[i];
      const key = `${year}||${monthNorm}||${s.key}||${concepto}`;
      const rec = latest.get(key);
      row[i + 2] = rec ? rec.valor : "";
    }
    out.push(row);
  }

  // Spreadsheet temporal
  const temp = SpreadsheetApp.create(`TEMP_VAP_EXPORT_${year}_${monthNorm}_${new Date().getTime()}`);
  const tempSheet = temp.getSheets()[0];
  tempSheet.setName(`Complementos_${year}_${monthNorm}`);
  tempSheet.getRange(1,1,out.length,out[0].length).setValues(out);

  tempSheet.setFrozenRows(1);
  tempSheet.autoResizeColumns(1, out[0].length);

  // Export robusto a XLSX sin Drive API
  const folder = DriveApp.getFolderById(EXPORT_FOLDER_ID);
  const outName = `VAP_COMPLEMENTOS_${year}_${monthToNum_(monthNorm)}.xlsx`;
  const file = exportSpreadsheetToXlsx_(temp.getId(), outName, folder);

  // Borrar temporal
  DriveApp.getFileById(temp.getId()).setTrashed(true);

  log_(ss, {
    action: "EXPORT_OK",
    n: out.length - 1,
    result: "OK",
    message: `Generado: ${file.getName()}`
  });

  ui.alert(`Excel generado y guardado en Drive:\n${file.getName()}`);
}

/**
 * Exporta un Google Spreadsheet a XLSX usando UrlFetchApp + OAuth.
 * - NO requiere activar Drive API (servicio avanzado).
 * - Evita "Drive is not defined" y problemas de blob PDF.
 */
function exportSpreadsheetToXlsx_(spreadsheetId, outFileName, folder) {
  const mime = "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet";
  const url = `https://www.googleapis.com/drive/v3/files/${encodeURIComponent(spreadsheetId)}/export?mimeType=${encodeURIComponent(mime)}`;

  const token = ScriptApp.getOAuthToken();
  const resp = UrlFetchApp.fetch(url, {
    method: "get",
    headers: { Authorization: `Bearer ${token}` },
    muteHttpExceptions: true
  });

  const code = resp.getResponseCode();
  if (code !== 200) {
    throw new Error(`Export XLSX falló. HTTP ${code}: ${resp.getContentText()}`);
  }

  const blob = resp.getBlob().setName(outFileName);
  return folder.createFile(blob);
}

